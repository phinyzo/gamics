# ── RAWG API ─────────────────────────────────────────────
RAWG_API_KEY=your_rawg_key_here

# ── SUPABASE ──────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── AFRICA'S TALKING (M-Pesa B2C payouts + SMS) ────────────
# Sign up: https://africastalking.com — use "sandbox" to test
# B2C docs: https://developers.africastalking.com/docs/payments/mobile-b2c
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox                    # change to your AT username in production
AT_BUSINESS_NUM=                       # your shortcode/paybill (leave blank for sandbox)

# ── RESEND (email notifications) ───────────────────────────
# Sign up free: https://resend.com — 3,000 emails/month free
RESEND_API_KEY=re_your_resend_key_here
RESEND_FROM=PhinTech Arena <arena@phintechsolutions.com>

# ── CRON SECURITY ──────────────────────────────────────────
# Random secret — include in Authorization: Bearer <secret> header on cron calls
# Generate with: openssl rand -hex 32
CRON_SECRET=change_this_to_a_random_secret_string
